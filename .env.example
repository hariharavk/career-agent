# --- Authentication (login credentials) ---
APP_USERNAME=admin
APP_PASSWORD=change-me
# Optional: explicit secret for signing login tokens. Defaults to the
# auto-generated encryption key if left blank.
AUTH_SECRET=

# --- AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Telegram notifications (optional) ---
# Can also be set from the Settings UI (stored encrypted in the DB) — this is a fallback,
# used only if the Settings UI fields are empty.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Healthcheck (optional) ---
# A healthchecks.io (or compatible) ping URL. The scheduled scraper pings this on every
# run (appending /fail on failure) — if the cron job stops firing entirely, healthchecks.io
# notices the ping stopped arriving and alerts you, which nothing inside this app can do
# for itself. Not pinged by manual "Run Scraper" triggers — only the actual schedule.
HEALTHCHECK_PING_URL=
